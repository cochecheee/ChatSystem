# =============================================================================
# Compose-level env file for chat-system stack (`docker compose up -d`).
# Copy to `.env` (consumed by docker-compose.example.yml) or `mcp/.env`
# (consumed by docker-compose.yml). Both files have the same shape.
# =============================================================================

# --- Database -----------------------------------------------------------------
# Inside the container the path is overridden to /data/mcp.db (volume).
# Outside Docker (uvicorn directly) the default is ./mcp.db.
DATABASE_URL=sqlite+aiosqlite:///./mcp.db

# --- GitHub (REQUIRED) --------------------------------------------------------
# PAT scopes: repo + workflow.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-target-repo

# --- Polling ------------------------------------------------------------------
POLLING_WORKFLOW_NAME=CI Workflow
POLLING_INTERVAL_SECONDS=300
POLLING_BRANCH=main

# --- Gemini AI (REQUIRED for /explain, /fix) ----------------------------------
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3

# --- Auth ---------------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-32+-random-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CI/CD integration --------------------------------------------------------
# Optional API key for POST /artifacts/process.
CI_API_KEY=

# Webhook bearer token — must match `MCP_WEBHOOK_TOKEN` secret in your CI repo.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CI_WEBHOOK_TOKEN=replace-me-with-32+-random-chars

# --- App ----------------------------------------------------------------------
APP_ENV=production

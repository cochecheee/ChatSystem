# =============================================================================
# MCP Gateway — Environment Variables
# Copy file này thành .env và điền giá trị thật trước khi chạy server.
# Xem docs/setup.md để hướng dẫn chi tiết từng biến.
#
# Development & Production: dùng credentials thật (không có mock mode).
# Mock chỉ dùng trong pytest (tự động — không cần cấu hình ở đây).
# =============================================================================

# --- Database ---
# SQLite tự tạo tại mcp/mcp.db khi server khởi động lần đầu
DATABASE_URL=sqlite+aiosqlite:///./mcp.db

# --- GitHub (BẮT BUỘC) ---
# PAT cần: repo (hoặc public_repo), workflow
# Hướng dẫn lấy: docs/setup.md#4-lấy-github-personal-access-token
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=cochecheee
GITHUB_REPO=sample-python

# --- Polling ---
# Phải khớp với field `name:` trong .github/workflows của target repo.
# "Security" = tên workflow trong cochecheee/sample-python (demo repo).
POLLING_WORKFLOW_NAME=Security
POLLING_INTERVAL_SECONDS=300
POLLING_BRANCH=main

# --- Gemini AI (BẮT BUỘC cho Phase 3) ---
# Hướng dẫn lấy: docs/setup.md#5-lấy-gemini-api-key
GEMINI_API_KEY=AIzaSy_your_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3

# --- Auth ---
# JWT secret — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string-of-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CI/CD Integration ---
# API Key cho POST /artifacts/process (để trống = tắt auth khi dev local)
CI_API_KEY=

# Legacy global webhook token. As of V3.5 each Project can rotate its own
# token via POST /projects/{id}/webhook/rotate — preferred over this global
# fallback because it lets per-project CIs use different secrets. Leave
# this empty for fresh installs; only set it if you have old CIs that
# can't be migrated to per-project tokens yet.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CI_WEBHOOK_TOKEN=

# --- Multi-tenant + RBAC (V2.8 + V3.0) ---
# Match Render deploy. Without these, single-tenant fallback hides
# per-project membership bugs that ship to prod.
MULTI_TENANT_ENABLED=true
RBAC_PER_PROJECT=true

# --- Fernet at-rest encryption (V2.8 A1) ---
# Encrypts github_token + gemini_api_key + webhook_token before INSERT.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Empty = plaintext (legacy single-tenant). Render sets this in env.
FERNET_KEY=

# --- App ---
APP_ENV=development

# =============================================================================
# MCP Gateway — Environment Variables
# Copy file này thành .env và điền giá trị thật trước khi chạy server.
# Development và Production đều dùng credentials thật (không có mock mode).
# Mock chỉ được dùng trong pytest (tự động, không cần cấu hình ở đây).
# =============================================================================

# --- Gemini AI (BẮT BUỘC) ---
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3

# --- GitHub (BẮT BUỘC để fetch CI artifacts) ---
# PAT cần permissions: actions:read, contents:read
# Lấy tại: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-java-repo-name

# --- Polling ---
POLLING_INTERVAL_SECONDS=300
POLLING_WORKFLOW_NAME=Security Scans

# --- Auth ---
SECRET_KEY=your-secret-key-for-jwt-signing-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- App ---
APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./mcp.db
